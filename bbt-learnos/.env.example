# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/bbt_learnos

# ─── Cache ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# ─── Video (Mux) ─────────────────────────────────────────────────────────────
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=

# ─── Payments ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=

EASYPAISA_STORE_ID=
EASYPAISA_HASH_KEY=

# ─── AWS ─────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_SES_FROM_EMAIL=noreply@bigbinarytech.com

# ─── Push Notifications ──────────────────────────────────────────────────────
FCM_SERVER_KEY=

# ─── OAuth ───────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=

# ─── Live Sessions (Daily.co) ────────────────────────────────────────────────
DAILY_API_KEY=
DAILY_DOMAIN=your-subdomain

# ─── ClickHouse (analytics) ──────────────────────────────────────────────────
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ─── Observability (Sentry) ──────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ─── Observability (Datadog) ──────────────────────────────────────────────────
DD_AGENT_HOST=localhost
DD_SERVICE=bbt-api
DD_ENV=development
DD_VERSION=

# ─── Frontend (public) ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_SITE_URL=https://bbt.edu.pk
NEXT_PUBLIC_SENTRY_DSN=
